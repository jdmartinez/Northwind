<div id="customer-profile" class="customer-profile">
    <div class="row customer-header">
        <i class="fa fa-user avatar img-circle"></i>
        <h3 class="name">{{contactName}}</h3>
        <span class="title">{{contactTitle}}</span>
    </div>

    <div class="row">
        <dl class="profile">
            <dt>Company Name</dt>
            <dd>{{companyName}}</dd>
            <dt class="separator"></dt>
            <dl></dl>
            <dt>Address</dt>
            <dd>{{address}}</dd>
            <dd>{{city}}</dd>
            <dd>{{postalCode}}</dd>
            <dd>{{country}}</dd>
            <dt class="separator"></dt>
            <dl></dl>
            <dt>Phone</dt>
            <dd>{{phone}}</dd>
        {{#if fax}}
            <dt>Fax</dt>
            <dd>{{fax}}</dd>
        {{/if}}
            <dt class="separator"></dt>
            <dl></dl>
            <dt>Mapa<dt>
            <dd>
                {{#google-map address=completeAddress width="100%" height="400px"}}
                    <h3>Mapa</h3>
                {{/google-map}}
            </dd>
        </dl>        
    </div>    
</div>
