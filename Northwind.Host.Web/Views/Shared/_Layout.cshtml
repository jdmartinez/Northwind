<!doctype html>
<html>
<head>
    <meta charset="utf-8">    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Northwind Restful Web API Browser">
    <meta name="author" content="Juan Diego Martinez">
    <title>Northwind RESTful Web API</title>
    <link rel="stylesheet" href="//netdna.bootstrapcdn.com/bootstrap/3.0.1/css/bootstrap.min.css">
    <link rel="stylesheet" href="//netdna.bootstrapcdn.com/font-awesome/4.0.1/css/font-awesome.min.css">
    @Html.RenderCssBundle("~/Content/css/style.css.bundle", BundleOptions.MinifiedAndCombined)

    <!--[if lt IE 9]>
      <script src="http://html5shim.googlecode.com/svn/trunk/html5.js"></script>
    <![endif]-->
</head>
<body>

    <script type="text/x-handlebars">        
        <!-- Header -->        
        <header class="navbar navbar-inverse" role="banner">            
            <div class="navbar-header">
                <!-- Button that toggle navigation sidebar in mobile devices -->
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="sidebar">
                    <span class="sr-only">Toggle navigation</span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <span class="navbar-brand">Northwind RESTful Web Api Explorer</span>
            </div>
        </header>
        <!-- End header -->
                    
        <!-- Sidebar -->
        <aside id="sidebar">
            <nav id="services-menu" class="collapse navbar-collapse" role="menu">
    	        <ul class="nav nav-stacked">
                {{#each api in controller.content}}
                    <li role="presentation">{{#link-to api.path}}<i {{bind-attr class=":fa api.icon :fa-lg"}}></i><span>{{api.name}}</span>{{/link-to}}</li>
                {{/each}}                   
                    <li class="divider" role="presentation"></li>
                    <li role="presentation">                        
                        {{#link-to 'about'}}
                            <i class="fa fa-info-circle fa-fw"></i>
                            <span>About</span>
                        {{/link-to}}
                    </li>
                </ul>
            </nav>
        </aside>
        <!-- End sidebar -->        

        <!-- Content -->            
        <section id="content">   
            <div class="row">
                <div class="col-md-12">
                    {{outlet}}
                </div>
            </div>
        </section>
    </script>

    <script type="text/x-handlebars" id="customers" data-template-name="customers">	
        <h1>Customers</h1>
	    {{view Northwind.CustomersView}}
    </script>    

    <script type="text/x-handlebars" id="orders" data-template-name="orders">
        <h1>Orders</h1>
        {{view Northwind.Common.Components.Grid.GridView}}
    </script>  

    <script type="text/x-handlebars" id="orders" data-template-name="suppliers">
        <h1>Suppliers</h1>
        {{view Northwind.Common.Components.Grid.GridView}}
    </script>  

    <script type="text/x-handlebars" id="customer" data-template-name="customer">           
        <p>            
            <h1 {{bind-attr class="isEditing:editing"}}>
            {{#if isEditing}}
                {{text-edit class="edit" value=contactName focus-out="acceptChanges"}}
            {{else}}
                <label {{action "edit" on="doubleClick"}}>{{contactName}}</label>
            {{/if}}
            </h1>            

            <h4>{{companyName}}</h4>
            <h5>{{contactTitle}}</h5>
        </p>
        <p>
            <span class="glyphicon glyphicon-envelope"></span> {{address}} <br/>
            {{postalCode}} {{city}} <br/>
            {{country}} <br/>
        </p>
        <p>
            <span class="glyphicon glyphicon-earphone"></span> {{phone}} <br/>
        </p>
    </script>    

