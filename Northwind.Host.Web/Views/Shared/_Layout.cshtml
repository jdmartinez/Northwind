    <script src="//netdna.bootstrapcdn.com/bootstrap/3.0.2/js/bootstrap.min.js"></script>
    <script src="/content/js/libs/holder.js"></script>
    <script src="/content/js/libs/handlebars-1.0.0.js"></script>
    <script src="/content/js/libs/ember.js"></script>
    <script src="/content/js/libs/ember-data.js"></script>
    @Html.RenderJsBundle("~/Content/js/app.js.bundle", BundleOptions.MinifiedAndCombined)

</body>
</html>
